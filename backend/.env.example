# Backend Environment Variables для Render
# Скопируйте эти переменные в Render Dashboard → Environment

# === База данных PostgreSQL ===
# Вставьте Internal Database URL из вашей БД Render
SPRING_DATASOURCE_URL=postgresql://forum_user:Rfvcbv123Ь@host:5432/forum_booking

# Имя пользователя БД
SPRING_DATASOURCE_USERNAME=forum_user

# Пароль от БД (укажите ваш пароль)
SPRING_DATASOURCE_PASSWORD=Rfvcbv123

# === Hibernate настройки ===
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# === Инициализация БД ===
SPRING_SQL_INIT_MODE=never

# === JWT Secret (безопасный ключ) ===
APP_JWT_SECRET=ForumBookingSecretKey2026Production!

# === CORS (разрешённые домены) ===
# Для тестов можно '*', потом замените на URL frontend
APP_CORS_ALLOWED_ORIGINS=*
