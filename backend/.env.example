# Шаблон переменных окружения для Backend
# Скопируйте этот файл в .env и заполните значения

# === База данных PostgreSQL ===
# Вариант 1: Использовать DATABASE_URL (рекомендуется для Render)
DATABASE_URL=postgresql://forum_user:ВАШ_ПАРОЛЬ@host:5432/forum_booking

# Вариант 2: Использовать отдельные переменные
# DB_HOST=host
# DB_PORT=5432
# DB_NAME=forum_booking
# DB_USER=forum_user
# DB_PASSWORD=ВАШ_ПАРОЛЬ

# === Hibernate настройки ===
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# === Инициализация БД ===
SPRING_SQL_INIT_MODE=never

# === JWT Secret (безопасный ключ) ===
APP_JWT_SECRET=ForumBookingSecretKey2026Production!

# === CORS (разрешённые домены) ===
# Для тестов можно '*', потом замените на URL frontend
APP_CORS_ALLOWED_ORIGINS=*

# === Порт сервера ===
SERVER_PORT=8080
